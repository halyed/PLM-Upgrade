# ── Domain ────────────────────────────────────────────────────────────────────
# Your DuckDNS subdomain (e.g. myplm.duckdns.org)
DOMAIN=yourapp.duckdns.org

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=plm
POSTGRES_USER=plm_user
POSTGRES_PASSWORD=change_me_strong_password

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_strong_password

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_strong_password
KC_DB_USER=keycloak
KC_DB_PASSWORD=change_me_strong_password
# Production settings — proxy Keycloak at /auth/ through nginx
KC_PROXY_HEADERS=xforwarded
KC_HTTP_RELATIVE_PATH=/auth
KC_HOSTNAME_URL=https://yourapp.duckdns.org/auth

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_strong_password

# ── DuckDNS (used by setup script for auto-renew) ────────────────────────────
DUCKDNS_TOKEN=your-duckdns-token

# ── Optional: Email notifications ─────────────────────────────────────────────
NOTIFICATION_EMAIL_ENABLED=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your@email.com
# SMTP_PASSWORD=your_app_password
